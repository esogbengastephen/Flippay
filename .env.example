# Backend API URL – REQUIRED for admin rate/min/toggles to apply on the buy page.
# If unset, the buy page shows default rate (50) and minimum (3000) and a warning banner.
# Local: http://localhost:3001
# Production (Vercel): set in Project → Settings → Environment Variables
NEXT_PUBLIC_API_URL=https://flippayback.vercel.app

# Supabase – required for auth, user dashboard, and realtime. Get from Supabase project → Settings → API.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here  # server-side only, for admin operations
